      "target": "http://backend:8000"
    }
  },
  "homepage": "/front",
  "dependencies": {
    "@date-io/core": "^1.3.6",
    "@date-io/moment": "^1.3.6",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@material-ui/core": "^4.9.14",
    "@material-ui/icons": "^4.9.1",
    "@material-ui/lab": "^4.0.0-alpha.58",
    "@material-ui/pickers": "^3.2.10",
    "classnames": "^2.2.6",
    "clsx": "^1.1.1",
    "http-client": "^4.3.1",
    "http-proxy": "^1.18.1",
    "lodash": "^4.17.15",
    "lodash-uuid": "^0.0.3",
    "material-table": "1.69.1",
    "moment": "^2.25.3",
    "process": "^0.11.10",
    "prop-types": "^15.7.2",
    "react": "^17.0.0",
    "react-autosuggest": "^10.0.2",
    "react-dom": "^17.0.0",
    "react-helmet": "^6.1.0",
    "react-intl": "^6.4.4",
    "react-redux": "^7.2.0",
    "redux": "^4.0.5",
    "redux-api-middleware": "^3.2.1",
    "redux-thunk": "^2.3.0",
    "serve": "^14.2.4",
    "shelljs": "^0.8.4",
    "zxcvbn": "^4.4.2",
    "@craco/craco": "^7.1.0",
    "ajv":"8.17.1"
  },
  "scripts": {
    "start": "craco start",
    "build": "craco build",
    "build-ci": "react-scripts build",
    "dev": "nodemon",
    "load-config": "node ./openimis-config.js",
    "postinstall": "node script/postinstall.js",
    "format": "prettier src -w",
    "check-package": "node script/check-package.js"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ],
    "rules": {
      "space-before-function-paren": 0,
      "react/jsx-boolean-value": 0
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "express": "^4.17.1",
    "http-proxy": "^1.18.1",
    "nodemon": "^3.1.10",
    "react-scripts": "^5.0.1",
    "webpack": "^5.99.9",
    "webpack-cli": "^6.0.1"
  }
}